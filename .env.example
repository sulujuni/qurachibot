# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Bot username (without @)
BOT_USERNAME=your_bot_username

# ─── Database ────────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production):
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/qurachibot

# SQLite fallback (for local development only):
# DATABASE_URL=sqlite+aiosqlite:///./giveaway_bot.db

# Connection pool settings (PostgreSQL only)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# ─── Admin ───────────────────────────────────────────────────────────────────────
# Admin user IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789,987654321

# ─── Web Dashboard ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Public HTTPS URL of the dashboard for the Telegram Web App "Dashboard" button.
# Set this to your tunnel URL / domain (must be HTTPS). Leave empty to disable.
WEB_URL=

# ─── Scaling ─────────────────────────────────────────────────────────────────────
# Max updates processed concurrently (removes the one-at-a-time bottleneck).
MAX_CONCURRENT_UPDATES=256

# ─── Webhook (self-hosted; optional, for production) ──────────────────────────────
# Leave USE_WEBHOOK=false to use polling (simplest; good for dev & small bots).
# For scale, set USE_WEBHOOK=true and put a reverse proxy (Caddy/nginx) with a
# free Let's Encrypt cert in front — no paid webhook service required.
USE_WEBHOOK=false
# Public HTTPS base URL Telegram will POST updates to (your domain):
WEBHOOK_URL=https://bot.example.com
# Internal interface/port the bot listens on (the proxy forwards to this):
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=8443
# Hard-to-guess path segment appended to WEBHOOK_URL:
WEBHOOK_PATH=telegram
# Shared secret so you can verify requests really came from Telegram
# (allowed chars: A-Z a-z 0-9 _ - , length 1-256). Generate a random one.
WEBHOOK_SECRET_TOKEN=

# ─── Referral ─────────────────────────────────────────────────────────────────────
# Channels a referred user must join for a referral to count (comma-separated).
# Leave empty to only require a real (non-bot) account.
REFERRAL_REQUIRED_CHANNELS=
