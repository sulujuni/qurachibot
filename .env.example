# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Bot username (without @)
BOT_USERNAME=your_bot_username

# ─── Database ────────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production):
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/qurachibot

# SQLite fallback (for local development only):
# DATABASE_URL=sqlite+aiosqlite:///./giveaway_bot.db

# Connection pool settings (PostgreSQL only)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# ─── Admin ───────────────────────────────────────────────────────────────────────
# Admin user IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789,987654321

# ─── Web Dashboard ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
